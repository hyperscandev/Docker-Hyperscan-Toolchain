{
  "name": "score-toolchain",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "mounts": [
    "source=../score-sdk,target=/score-sdk,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "PATH": "/opt/score-toolchain/bin:${containerEnv:PATH}"
  },
   "containerEnv": {
  "C_INCLUDE_PATH": "/score-sdk/include",
  "LIBRARY_PATH": "/score-sdk/lib"
},
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "terminal.integrated.cwd": "/workspace"
      }
    }
  }
}